<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- GitLab webhook secret token (X-Gitlab-Token) -->
    <add key="GitLab:WebhookSecret" value="your-secret-token-here" />

    <!-- Webhook receiver HTTP server settings -->
    <add key="Webhook:Host" value="localhost" />
    <add key="Webhook:Port" value="8080" />

    <!-- GitLab Integration Configuration (Issue #5) -->

    <!-- Base URL of the GitLab instance (required, must be https://) -->
    <add key="GitLab:BaseUrl" value="https://gitlab.example.com" />

    <!-- Target repository URL where agent will make code changes (required) -->
    <add key="GitLab:TargetRepoUrl" value="https://github.com/example/target-repo" />

    <!-- Optional target branch/ref (empty = use repo default) -->
    <add key="GitLab:TargetRepoRef" value="" />

    <!-- Enable or disable the integration (default: false) -->
    <add key="GitLab:Enabled" value="false" />

    <!-- Optional human-readable label for the GitLab instance -->
    <add key="GitLab:DisplayName" value="GitLab" />
  </appSettings>
</configuration>
