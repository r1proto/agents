<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- GitLab Integration Configuration -->

    <!-- GitLab instance base URL (REQUIRED - must use HTTPS) -->
    <add key="GitLab:BaseUrl" value="https://gitlab.example.com" />

    <!-- GitLab webhook secret token for X-Gitlab-Token header validation (REQUIRED) -->
    <add key="GitLab:WebhookSecret" value="your-secret-token-here" />

    <!-- Target repository URL where the OpenCode agent will work (REQUIRED) -->
    <!-- This is separate from the GitLab project where issues are filed -->
    <add key="GitLab:TargetRepoUrl" value="https://github.com/yourorg/yourrepo" />

    <!-- Optional: Target branch/ref for the agent to start from -->
    <!-- Leave empty to use the repository's default branch -->
    <add key="GitLab:TargetRepoRef" value="" />

    <!-- Optional: Display name for the GitLab instance -->
    <add key="GitLab:DisplayName" value="GitLab" />

    <!-- Enable or disable the GitLab integration (true/false, 1/0, yes/no) -->
    <!-- Set to true to enable agent submission, false to use stub dispatcher -->
    <add key="GitLab:Enabled" value="false" />

    <!-- Webhook receiver HTTP server settings -->
    <add key="Webhook:Host" value="localhost" />
    <add key="Webhook:Port" value="8080" />

    <!-- GitLab Integration Configuration (Issue #5) -->

    <!-- Base URL of the GitLab instance (required, must be https://) -->
    <add key="GitLab:BaseUrl" value="https://gitlab.example.com" />

    <!-- Target repository URL where agent will make code changes (required) -->
    <add key="GitLab:TargetRepoUrl" value="https://github.com/example/target-repo" />

    <!-- Optional target branch/ref (empty = use repo default) -->
    <add key="GitLab:TargetRepoRef" value="" />

    <!-- Enable or disable the integration (default: false) -->
    <add key="GitLab:Enabled" value="false" />

    <!-- Optional human-readable label for the GitLab instance -->
    <add key="GitLab:DisplayName" value="GitLab" />
  </appSettings>
</configuration>
