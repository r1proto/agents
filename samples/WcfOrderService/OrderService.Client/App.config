<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <system.serviceModel>
    <client>
      <endpoint name="OrderServiceEndpoint"
                address="http://localhost:8080/orders"
                binding="basicHttpBinding"
                bindingConfiguration="OrderServiceBinding"
                contract="OrderService.Contracts.IOrderService" />
    </client>
    <bindings>
      <basicHttpBinding>
        <binding name="OrderServiceBinding"
                 maxReceivedMessageSize="65536"
                 receiveTimeout="00:01:00"
                 sendTimeout="00:01:00">
          <security mode="None" />
        </binding>
      </basicHttpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
