{
  "$schema": "https://opencode.ai/config.json",
  "//": "This file is a production-grade template for an OpenCode agent pack. Customize models, tools, permissions, and prompts before production use.",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "description": "Template planning agent for analyzing requests and proposing safe implementation plans.",
      "mode": "primary",
      "model": "REPLACE_WITH_MODEL",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "build-specialist": {
      "description": "Template build agent for safe, minimal, verified code changes.",
      "mode": "primary",
      "model": "REPLACE_WITH_MODEL",
      "prompt": "{file:./prompts/build-specialist.txt}",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "reviewer": {
      "description": "Template review subagent for correctness, maintainability, and safety review.",
      "mode": "subagent",
      "model": "REPLACE_WITH_MODEL",
      "prompt": "{file:./agents/reviewer.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "design-gate": {
      "description": "Gate 1 subagent: assesses whether a technical specification is sufficiently detailed to begin coding a .NET 8 / RabbitMQ / EFCore feature.",
      "mode": "subagent",
      "model": "REPLACE_WITH_MODEL",
      "prompt": "{file:./agents/design-gate.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "coding-gate": {
      "description": "Gate 2 subagent: assesses whether the coding agent has enough context (spec + codebase) to safely implement the feature.",
      "mode": "subagent",
      "model": "REPLACE_WITH_MODEL",
      "prompt": "{file:./agents/coding-gate.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "bash": "ask"
      }
    },
    "dotnet-feature-coder": {
      "description": "Coding agent specialized for .NET 8 / RabbitMQ / EFCore feature development on an existing codebase. Runs only after both gates pass.",
      "mode": "primary",
      "model": "REPLACE_WITH_MODEL",
      "prompt": "{file:./agents/dotnet-feature-coder.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  }
}